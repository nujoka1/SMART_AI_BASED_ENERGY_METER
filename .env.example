# Copy this file to .env (project root) and replace values for each environment.
# Frontend (React) environment variables — used by the dashboard build.
# Keep these out of public repos. Use CI secret storage for production builds.
REACT_APP_FIREBASE_API_KEY=your_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
REACT_APP_FIREBASE_DATABASE_URL=https://your_project.firebaseio.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id_here
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
REACT_APP_FIREBASE_APP_ID=your_app_id_here

# AI Engine Configuration (Python Backend)
# The AI engine reads AI_FIREBASE_URL and AI_FIREBASE_SECRET from the environment.
# For safety, do NOT commit AI_FIREBASE_SECRET to source control; use a secrets manager.
AI_FIREBASE_URL=https://your_project.firebaseio.com
AI_FIREBASE_SECRET=your_firebase_secret_key
AI_POLL_INTERVAL=5
AI_WRITE_INTERVAL=10
AI_ANOMALY_THRESHOLD=2.5
AI_PREPAID_UNITS_KWH=55776
AI_LOG_LEVEL=INFO

# Firmware configuration note:
# The ESP32 firmware stores sensitive WiFi and Firebase secrets on-device.
# For production, prefer to set these at build time using PlatformIO build flags
# or supply a separate `firmware/config.h` that is excluded from version control.
