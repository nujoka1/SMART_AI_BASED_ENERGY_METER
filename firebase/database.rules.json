{
  "rules": {
    ".read": false,
    ".write": false,

    "meter_serials": {
      "$serial": {
        ".read": true,
        ".write": "auth != null"
      }
    },

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },

